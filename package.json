{
  "name": "@dexterai/mpp",
  "version": "0.2.0",
  "description": "Dexter managed Solana settlement for the Machine Payments Protocol",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/methods.d.ts",
      "import": "./dist/methods.js"
    },
    "./server": {
      "types": "./dist/server/charge.d.ts",
      "import": "./dist/server/charge.js"
    },
    "./client": {
      "types": "./dist/client/charge.d.ts",
      "import": "./dist/client/charge.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "import": "./dist/api.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "import": "./dist/constants.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18.7.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "mppx": "^0.3.15",
    "@solana/kit": "^2.1.0",
    "@solana-program/token": "^0.5.0",
    "@solana-program/compute-budget": "^0.7.0"
  },
  "devDependencies": {
    "mppx": "^0.3.15",
    "@solana/kit": "^2.1.0",
    "@solana-program/token": "^0.5.0",
    "@solana-program/compute-budget": "^0.7.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "solana",
    "mpp",
    "payments",
    "x402",
    "dexter",
    "usdc",
    "machine-payments"
  ],
  "author": "Dexter DAO",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Dexter-DAO/dexter-mpp"
  }
}
